# Public API (services/api)
APP_ENV=dev                                  # dev | staging | prod
LOG_LEVEL=debug                              # debug | info | warn | error
HTTP_LISTEN_ADDR=:8080
ADMIN_LISTEN_ADDR=:8081

# Database
DATABASE_URL=postgres://buocvang:buocvang@localhost:5432/buocvang?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# Redis
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO local / S3 prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_BUCKET=buocvang-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true

# JWT — RS256, sinh bằng `openssl genrsa -out private.pem 2048`
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h                         # 30 ngày

# Zalo Mini App
ZALO_APP_ID=                                 # Lấy từ Zalo Mini App console
ZALO_APP_SECRET=                             # Server-side only
ZALO_OA_ID=                                  # Official Account để gửi notification
ZALO_OAUTH_REDIRECT=https://api.buocvang.vn/auth/zalo/callback

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=https://api.buocvang.vn/strava/oauth/callback
STRAVA_VERIFY_TOKEN=                         # Webhook verify token (random 32 bytes)

# Anti-fraud
ANTIFRAUD_MAX_DAILY_STEPS=60000              # Hard cap mỗi user/ngày
ANTIFRAUD_MIN_CADENCE_PERIOD_MS=300          # Step period < 300ms = flag
ANTIFRAUD_MAX_CADENCE_PERIOD_MS=900          # Step period > 900ms khi chạy = flag
ANTIFRAUD_AUTO_SUSPEND_SCORE=90              # Score ≥ 90 trong 3 ngày → auto suspend

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=buocvang-api

# Admin auth (OIDC nội bộ — Google Workspace)
ADMIN_OIDC_ISSUER=https://accounts.google.com
ADMIN_OIDC_CLIENT_ID=
ADMIN_OIDC_CLIENT_SECRET=
ADMIN_OIDC_REDIRECT_URI=https://admin.buocvang.vn/oidc/callback
ADMIN_ALLOWED_DOMAINS=buocvang.vn            # Comma-separated email domains

# Miniapp (Vite — VITE_ prefix mới expose ra client)
VITE_API_BASE_URL=http://localhost:8080
VITE_DEFAULT_LOCALE=vi
